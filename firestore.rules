rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Common security validators
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Type and Attribute validators to prevent poisoning or injection attacks
    function isValidTransaction(data) {
      return data.id is string && data.id.size() <= 128
        && data.type is string && (data.type == 'earnings' || data.type == 'expenses')
        && data.description is string && data.description.size() <= 200
        && data.amount is number && data.amount >= 0
        && data.category is string && data.category.size() <= 100
        && data.date is string && data.date.size() <= 50
        && data.profileId is string && data.profileId.size() <= 128
        && data.userId is string;
    }

    function isValidMonthlyBill(data) {
      return data.id is string && data.id.size() <= 128
        && data.description is string && data.description.size() <= 200
        && data.amount is number && data.amount >= 0
        && data.dueDate is string && data.dueDate.size() <= 100
        && data.category is string && data.category.size() <= 100
        && data.isPaid is bool
        && data.profileId is string && data.profileId.size() <= 128
        && data.userId is string;
    }

    function isValidInvestment(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.type is string && (data.type == 'Renda Fixa' || data.type == 'Ações' || data.type == 'Fundos Imobiliários' || data.type == 'Cripto' || data.type == 'Outros')
        && data.amountInvested is number && data.amountInvested >= 0
        && data.currentAmount is number && data.currentAmount >= 0
        && data.acquisitionDate is string && data.acquisitionDate.size() <= 50
        && data.broker is string && data.broker.size() <= 200
        && data.profileId is string && data.profileId.size() <= 128
        && data.userId is string;
    }

    function isValidFinancialGoal(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.targetAmount is number && data.targetAmount >= 0
        && data.currentAmount is number && data.currentAmount >= 0
        && data.profileId is string && data.profileId.size() <= 128
        && data.userId is string;
    }

    function isValidTrashTransaction(data) {
      return data.id is string && data.id.size() <= 128
        && data.deletedAt is string && data.deletedAt.size() <= 100
        && data.profileId is string && data.profileId.size() <= 128
        && data.userId is string;
    }

    function isValidUser(data) {
      return data.email is string && data.email.size() <= 150
        && data.createdAt is string && data.createdAt.size() <= 100
        && (!('username' in data) || (data.username is string && data.username.size() <= 100))
        && (!('passwordHash' in data) || (data.passwordHash is string && data.passwordHash.size() <= 150))
        && (!('profilesJson' in data) || (data.profilesJson is string))
        && (!('preferencesJson' in data) || (data.preferencesJson is string));
    }

    // Rules for individual resource domains (Transactions, Bills, Investments, Users, Trash)

    match /users/{userId} {
      allow read, write, delete: if true;
    }

    match /transactions/{transactionId} {
      allow read, write, delete: if true;
    }

    match /monthly_bills/{billId} {
      allow read, write, delete: if true;
    }

    match /investments/{investmentId} {
      allow read, write, delete: if true;
    }

    match /financial_goals/{goalId} {
      allow read, write, delete: if true;
    }

    match /trash_transactions/{trashId} {
      allow read, write, delete: if true;
    }
  }
}
